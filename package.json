{
  "name": "debtrac",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm --filter @debtrac/web build",
    "test": "pnpm --filter @debtrac/web test",
    "lint": "pnpm -r --parallel lint",
    "deploy": "pnpm build && pnpm --filter @debtrac/api run deploy"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "onlyBuiltDependencies": ["workerd", "esbuild", "@swc/core", "sharp"]
  }
}
